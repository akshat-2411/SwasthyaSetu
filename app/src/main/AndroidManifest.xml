<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.SEND_SMS" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.VIBRATE"/>

    <uses-feature
        android:name="android.hardware.telephony"
        android:required="false" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SwasthyaSetu">

        <!-- Google Maps API Key -->
        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="@string/places_web_api_key" />

        <!-- Splash Screen — new Launcher activity -->
        <activity
            android:name=".view.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.SwasthyaSetu.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".view.MainActivity"
            android:exported="false"
            android:label="@string/app_name"
            android:theme="@style/Theme.SwasthyaSetu" />

        <!-- Login Screen — Google Sign-In (immersive, no action bar) -->
        <activity
            android:name=".view.LoginActivity"
            android:exported="false"
            android:theme="@style/Theme.SwasthyaSetu.NoActionBar" />

        <activity
            android:name=".view.ChatActivity"
            android:exported="false"
            android:label="@string/action_ai_health_chat"
            android:theme="@style/Theme.SwasthyaSetu"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".view.MapActivity"
            android:exported="false"
            android:label="@string/action_find_hospitals"
            android:theme="@style/Theme.SwasthyaSetu" />

        <activity
            android:name=".view.SymptomActivity"
            android:exported="false"
            android:label="@string/symptom_title"
            android:theme="@style/Theme.SwasthyaSetu" />

        <activity
            android:name=".view.ResultActivity"
            android:exported="false"
            android:label="@string/result_title"
            android:theme="@style/Theme.SwasthyaSetu" />

        <activity
            android:name=".view.ProfileActivity"
            android:exported="false"
            android:label="@string/profile_title"
            android:theme="@style/Theme.SwasthyaSetu"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".view.AlertDetailActivity"
            android:exported="false"
            android:label="@string/alert_detail_title"
            android:theme="@style/Theme.SwasthyaSetu" />

        <activity
            android:name=".view.VaccinationActivity"
            android:exported="false"
            android:label="@string/vaccine_tracker_title"
            android:theme="@style/Theme.SwasthyaSetu" />

        <activity
            android:name=".view.FirstAidActivity"
            android:exported="false"
            android:label="@string/first_aid_title"
            android:theme="@style/Theme.SwasthyaSetu" />

        <activity
            android:name=".view.FirstAidDetailActivity"
            android:exported="false"
            android:label="@string/first_aid_title"
            android:theme="@style/Theme.SwasthyaSetu" />

        <activity
            android:name=".view.HistoryActivity"
            android:exported="false"
            android:label="@string/history_title"
            android:theme="@style/Theme.SwasthyaSetu" />

        <activity
            android:name=".view.AddReminderActivity"
            android:exported="false"
            android:label="@string/reminder_title"
            android:theme="@style/Theme.SwasthyaSetu"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".view.ReminderListActivity"
            android:exported="false"
            android:label="@string/reminder_title"
            android:theme="@style/Theme.SwasthyaSetu" />

        <activity
            android:name=".view.HospitalDetailActivity"
            android:exported="false"
            android:label="Hospital Profile"
            android:theme="@style/Theme.SwasthyaSetu.NoActionBar" />

        <activity
            android:name=".view.MyAppointmentsActivity"
            android:exported="false"
            android:label="My Appointments"
            android:theme="@style/Theme.SwasthyaSetu" />

        <activity android:name=".view.ScannerActivity"/>

        <service
            android:name=".service.MyFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <!-- Alarm Broadcast Receiver -->
        <receiver
            android:name=".receiver.ReminderBroadcastReceiver"
            android:exported="false" />

    </application>

</manifest>