<?xml version="1.0" encoding="utf-8"?>
<!-- Medical-themed background for the login screen -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Base white background -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/white" />
        </shape>
    </item>

    <!-- Soft teal gradient overlay (bottom-left to top-right) -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#0D00796B"
                android:centerColor="#0548A999"
                android:endColor="#0DB2DFDB"
                android:angle="135"
                android:type="linear" />
        </shape>
    </item>

    <!-- Large subtle circle — top-right -->
    <item
        android:top="-100dp"
        android:right="-60dp">
        <shape android:shape="oval">
            <solid android:color="#0A00796B" />
            <size android:width="280dp" android:height="280dp" />
        </shape>
    </item>

    <!-- Medium circle — bottom-left -->
    <item
        android:bottom="-80dp"
        android:left="-40dp">
        <shape android:shape="oval">
            <solid android:color="#0848A999" />
            <size android:width="220dp" android:height="220dp" />
        </shape>
    </item>

    <!-- Small accent circle — center-right -->
    <item
        android:top="300dp"
        android:right="-30dp">
        <shape android:shape="oval">
            <solid android:color="#06B2DFDB" />
            <size android:width="140dp" android:height="140dp" />
        </shape>
    </item>

</layer-list>
