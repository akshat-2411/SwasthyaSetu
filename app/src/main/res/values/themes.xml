<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.SwasthyaSetu" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorSecondaryVariant">@color/secondary_dark</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorError">@color/accent_emergency</item>
        <item name="colorOnError">@color/white</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:statusBarColor">@color/primary_dark</item>
        <item name="android:navigationBarColor">@color/primary_dark</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_hint</item>
    </style>

    <style name="Widget.SwasthyaSetu.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">4dp</item>
        <item name="contentPadding">16dp</item>
        <item name="cardBackgroundColor">@color/card_background</item>
    </style>

    <style name="Widget.SwasthyaSetu.SOSButton" parent="Widget.MaterialComponents.Button">
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/text_on_emergency</item>
        <item name="backgroundTint">@color/accent_emergency</item>
        <item name="cornerRadius">28dp</item>
        <item name="android:paddingTop">16dp</item>
        <item name="android:paddingBottom">16dp</item>
        <item name="iconTint">@color/white</item>
        <item name="elevation">8dp</item>
        <item name="rippleColor">@color/ripple_emergency</item>
    </style>

    <style name="TextAppearance.SwasthyaSetu.Greeting" parent="TextAppearance.MaterialComponents.Headline5">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="TextAppearance.SwasthyaSetu.Subtitle" parent="TextAppearance.MaterialComponents.Subtitle1">
        <item name="android:textColor">@color/text_secondary</item>
    </style>
    <style name="TextAppearance.SwasthyaSetu.SectionHeader" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textColor">@color/primary</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="TextAppearance.SwasthyaSetu.CardTitle" parent="TextAppearance.MaterialComponents.Subtitle1">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="TextAppearance.SwasthyaSetu.CardDescription" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <!-- No Action Bar theme — immersive, teal status bar -->
    <style name="Theme.SwasthyaSetu.NoActionBar" parent="Theme.SwasthyaSetu">
        <item name="windowNoTitle">true</item>
        <item name="windowActionBar">false</item>
        <item name="android:statusBarColor">#00796B</item>
        <item name="android:navigationBarColor">#00796B</item>
    </style>

    <!-- Splash Screen theme — inherits NoActionBar + fullscreen -->
    <style name="Theme.SwasthyaSetu.Splash" parent="Theme.SwasthyaSetu.NoActionBar">
        <item name="android:windowFullscreen">true</item>
    </style>

</resources>
