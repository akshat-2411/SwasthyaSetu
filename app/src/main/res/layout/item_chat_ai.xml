<?xml version="1.0" encoding="utf-8"?>
<!-- AI message bubble: left-aligned, light surface background -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingTop="4dp"
    android:paddingBottom="4dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="start"
        android:layout_marginEnd="64dp"
        android:background="@drawable/bg_chat_ai"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            android:id="@+id/tvAiLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/chat_ai_label"
            android:textColor="@color/primary"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvAiMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:lineSpacingExtra="4dp"
            android:textAlignment="viewStart"
            android:textColor="@color/text_primary"
            android:textDirection="locale"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/tvAiTimestamp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginTop="4dp"
            android:textColor="@color/text_hint"
            android:textSize="11sp" />

    </LinearLayout>

</FrameLayout>
