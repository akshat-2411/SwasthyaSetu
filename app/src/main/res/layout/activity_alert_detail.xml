<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background"
    tools:context=".view.AlertDetailActivity">

    <!-- Top AppBar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primary"
        app:navigationIcon="@drawable/ic_back_arrow"
        app:navigationIconTint="@color/white"
        app:title="@string/alert_detail_title"
        app:titleTextColor="@color/white" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Dynamic Header Card (Status) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardStatusHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="6dp"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:id="@+id/layoutStatusHeader"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="24dp"
                    android:background="#FFEBEE">

                    <ImageView
                        android:id="@+id/ivAlertIconDetailed"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_warning"
                        app:tint="#D32F2F" />

                    <TextView
                        android:id="@+id/tvAlertStatusTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:textColor="#D32F2F"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textAlignment="center"
                        tools:text="DENGUE OUTBREAK: HIGH RISK" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Loading Progress -->
            <LinearLayout
                android:id="@+id/layoutLoading"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginTop="32dp"
                android:visibility="visible">

                <ProgressBar
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:indeterminateTint="@color/primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/alert_loading"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- AI Content Fields -->
            <LinearLayout
                android:id="@+id/layoutAiContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                tools:visibility="visible">

                <!-- Section 1: What is happening? -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/alert_section_what_is_happening"
                    android:textAppearance="@style/TextAppearance.SwasthyaSetu.SectionHeader"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvWhatIsHappening"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:lineSpacingExtra="4dp"
                    android:layout_marginBottom="24dp"
                    tools:text="A severe dengue outbreak has been reported in your sector. Over 100 mosquitos test positive..." />

                <!-- Section 2: Symptoms -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/alert_section_symptoms"
                    android:textAppearance="@style/TextAppearance.SwasthyaSetu.SectionHeader"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvSymptoms"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:lineSpacingExtra="4dp"
                    android:layout_marginBottom="24dp"
                    tools:text="• High Fever\n• Severe Joint and Muscle Pain\n• Fatigue\n• Nausea\n• Skin Rash" />

                <!-- Section 3: Precautionary Steps -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/alert_section_precautions"
                    android:textAppearance="@style/TextAppearance.SwasthyaSetu.SectionHeader"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvPrecautions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:lineSpacingExtra="4dp"
                    android:layout_marginBottom="24dp"
                    tools:text="1. Use mosquito repellents containing DEET.\n2. Wear long-sleeved clothing.\n3. Empty stagnant water around your home." />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Action Area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface"
        android:elevation="8dp"
        android:padding="16dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCallHelpline"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/alert_btn_helpline"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="28dp"
            app:backgroundTint="#d32f2f" />

    </LinearLayout>

</LinearLayout>
